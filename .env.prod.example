# ============================================================
# PulseAI — Production Environment Template
# Copy to .env and fill in real values before deploying
# NEVER commit the real .env file
# ============================================================

# ─── App ────────────────────────────────────────────────────
ENVIRONMENT=production
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_min_64_char_random_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=pulseai
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=pulseai_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://pulseai:CHANGE_ME_strong_db_password@postgres:5432/pulseai_db

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-domain.com

# ─── AI / LLM Provider (choose one) ────────────────────────
# Option A: Azure OpenAI (recommended for production — PHI safe)
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=CHANGE_ME_azure_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Option B: OpenAI directly (ensure BAA signed)
OPENAI_API_KEY=sk-CHANGE_ME

# Option C: Google Gemini
GEMINI_API_KEY=CHANGE_ME_gemini_key

# ─── LangSmith Observability ────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__CHANGE_ME_langsmith_key
LANGCHAIN_PROJECT=pulseai-production

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.your-domain.com
