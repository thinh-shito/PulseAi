# Environment — PulseAI Backend
# Copy this to .env and fill in your values

# ─── App ───────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-min-32-chars-change-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ──────────────────────────────────────
POSTGRES_USER=pulseai
POSTGRES_PASSWORD=pulseai_secret
POSTGRES_DB=pulseai_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://pulseai:pulseai_secret@postgres:5432/pulseai_db

# ─── Redis ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Azure OpenAI (Primary LLM) ────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ─── Fallback LLM (dev only) ───────────────────────
OPENAI_API_KEY=your-openai-key-for-dev-only
GEMINI_API_KEY=your-gemini-key-for-dev-only

# ─── LangSmith Observability ───────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=pulseai-production

# ─── Langfuse (Alternative observability) ──────────
LANGFUSE_SECRET_KEY=your-langfuse-secret
LANGFUSE_PUBLIC_KEY=your-langfuse-public
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── CORS ──────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://app.pulseai.hospital
